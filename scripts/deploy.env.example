# Copy to deploy.env (same folder) and fill in. Keep deploy.env out of git.
#
#   cp scripts/deploy.env.example scripts/deploy.env
#
# Before first deploy (password-protected key — enter passphrase once):
#   ssh-add --apple-use-keychain ~/.ssh/id_rsa_sumbaprop
#
# Confirm SSH_USER and /home/SSH_USER/... paths in cPanel → File Manager.

# Server (IP or hostname — both resolve to the same host here)
SSH_HOST=84.247.175.224
# SSH_HOST=sumbaprop.com

# cPanel username (must match /home/USERNAME/...)
SSH_USER=sumbap

SSH_PORT=22

# Private key (same pattern as Sumba Core deploy.sh)
SSH_KEY="${HOME}/.ssh/id_rsa_sumbaprop"

# Remote paths — verify under your account
REMOTE_PUBLIC=/home/sumbap/public_html/download.sumbaprop.com
REMOTE_PRIVATE=/home/sumbap/private_files/downloads

# Optional: reuse one SSH connection for all rsyncs (faster; flaky Wi‑Fi → set 0)
USE_SSH_MUX=0

# Optional: rsync --checksum (slower, catches same-size changes). 0=off (like deploy.sh)
RSYNC_CHECKSUM=0

# Optional: rsync --delete on public tree only. 0=off
PUBLIC_DELETE=0

# Dry run: use the command line so it always wins over any variable in this file:
#   DRY_RUN=1 ./scripts/deploy_downloads.sh
